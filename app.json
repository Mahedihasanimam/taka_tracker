{
  "expo": {
    "name": "MoneyMaster",
    "slug": "MoneyMaster",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/androidicon.png",
    "scheme": "MoneyMaster",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mahedidev.Moneymaster"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/androidicon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.mahedidev.Moneymaster"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/androidicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "supabaseUrl": "https://cptyqpltmqugttwosqje.supabase.co",
      "supabaseAnonKey": "sb_publishable_Ez-03gDL3v-sbrbACFq_Kg_kCF-8AvC"
    }
  }
}

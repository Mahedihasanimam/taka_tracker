{
  "expo": {
    "name": "MoneyMaster",
    "slug": "MoneyMaster",
    "version": "1.0.0",
    "orientation": "portrait",
    "jsEngine": "hermes",
    "icon": "./assets/images/androidicon.png",
    "scheme": "moneymaster",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mahedidev.Moneymaster"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/androidicon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.mahedidev.Moneymaster"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/androidicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone for voice expense entry.",
          "speechRecognitionPermission": "Allow $(PRODUCT_NAME) to convert your speech into transactions."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-sqlite",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "BudgetStatusWidgetAndroid",
              "label": "Budget Snapshot",
              "description": "Money Master overview with balance, spending, and budget progress.",
              "minWidth": "180dp",
              "minHeight": "110dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "maxResizeWidth": "320dp",
              "maxResizeHeight": "220dp",
              "previewImage": "./assets/images/budget.png",
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 0
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "supabaseUrl": "https://cptyqpltmqugttwosqje.supabase.co",
      "supabaseAnonKey": "sb_publishable_Ez-03gDL3v-sbrbACFq_Kg_kCF-8AvC"
    }
  }
}
